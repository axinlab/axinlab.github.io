---
import { Image } from "astro:assets";
import type { Project } from "../types/config";
import {marked} from "marked"

type Props = Project;

const { title, description, image, year, url } = Astro.props;

const htmlDescription = marked.parse(description)
const isExternal = url.startsWith("http")
---

<a
  href={url}
  target={isExternal ? "_blank" : "_self"}
  class="group/card sm:py-5 py-10 px-4 -mx-4 rounded-xl flex flex-col sm:flex-row gap-6 transition-all duration-300 hover:bg-white/[0.04] hover:scale-[1.01]"
>
  <div class="h-full bg-gray-700 rounded-lg aspect-video sm:h-[150px]">
    <Image
      width={1920}
      height={1080}
      src={image}
      alt={title}
      class="w-full h-full object-cover rounded-lg aspect-video"
    />
  </div>
  <div>
    <div class="flex items-center gap-1 mb-2">
      <h2 class="font-medium transition-colors duration-300 group-hover/card:text-accent">
        {title}
      </h2>
      <span class="opacity-60">· {year}</span>
    </div>
    <div class="opacity-60">
      <Fragment set:html={htmlDescription} />
    </div>
  </div>
</a>
