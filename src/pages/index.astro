---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import { homePageContent, identity, projectsPageContent } from "../config";
import SocialLink from "../components/SocialLink.astro";
import Link from "../components/Link.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("posts");
posts.sort((a, b) => {
  const dateA = new Date(a.data.pubDate).getTime();
  const dateB = new Date(b.data.pubDate).getTime();
  return dateB - dateA;
});
posts.splice(2)
---

<Layout seo={homePageContent.seo}>
  <section class="reveal mt-10 max-w-2xl mx-auto px-6">
    <h1 class="font-bold text-3xl mb-1">
      {identity.name}<span class="text-accent">.</span>
    </h1>
    <p class="opacity-60 mb-10">{homePageContent.role}</p>
    <div class="flex flex-col min-[520px]:flex-row gap-6 mb-8">
      <Image
        src={identity.logo}
        alt={identity.name}
        width={100}
        height={100}
        class="rounded-full ring-2 ring-white/10 hover:ring-accent transition-all duration-300 hover:scale-105"
      />
      <div class="group flex flex-col justify-center gap-2 w-fit">
        {
          homePageContent.socialLinks.map((link) => (
            <SocialLink
              title={link.title}
              url={link.url}
              icon={link.icon}
              external={link.external}
            />
          ))
        }
      </div>
    </div>
    <p class="max-w-md mb-8">
      {homePageContent.description}
    </p>
    <div class="flex items-center gap-4 group w-fit">
      {
        homePageContent.links.map((link) => (
          <Link text={link.title} href={link.url} external={link.external} />
        ))
      }
    </div>
  </section>

  <section class="reveal mt-20 max-w-2xl mx-auto px-6">
    <h2 class="text-sm font-semibold uppercase tracking-widest text-accent">
      Latest Case Studies
    </h2>
    <div class="grid grid-cols-1 mb-10">
      {
        projectsPageContent.projects.slice(0, 3).map((project) => (
          <ProjectCard {...project} />
        ))
      }
    </div>
    <div class="text-center">
      <a
        href="/projects"
        class="group/link inline-flex items-center gap-2 rounded-full border border-white/10 px-5 py-2.5 text-sm font-medium opacity-70 hover:opacity-100 hover:border-accent transition-all duration-300"
        >View all
        <span
          aria-hidden="true"
          class="transition-transform duration-300 group-hover/link:translate-x-0.5"
          >→</span
        ></a
      >
    </div>
  </section>

