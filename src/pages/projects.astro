---
import Layout from "../layouts/Layout.astro";
import { projectsPageContent } from "../config";
import ProjectCard from "../components/ProjectCard.astro";

const caseStudies = projectsPageContent.projects.filter(
  (project) => project.category !== "hackathon"
);
const hackathonProjects = projectsPageContent.projects.filter(
  (project) => project.category === "hackathon"
);
---

<Layout seo={projectsPageContent.seo}>
  <section class="reveal mt-10 max-w-2xl mx-auto px-6">
    <h1 class="font-bold text-3xl mb-1">
      My Work<span class="text-accent">.</span>
    </h1>
  </section>

  <section class="max-w-2xl mx-auto px-6 mt-12">
    <h2 class="text-sm font-semibold uppercase tracking-widest text-accent mb-4">
      Case Studies
    </h2>
    <div class="grid grid-cols-1">
      {caseStudies.map((project) => <ProjectCard {...project} />)}
    </div>
  </section>

  <section class="max-w-2xl mx-auto px-6 mt-12 mb-16">
    <h2 class="text-sm font-semibold uppercase tracking-widest text-accent mb-4">
      Awarded Projects
    </h2>
    <div class="grid grid-cols-1">
      {hackathonProjects.map((project) => <ProjectCard {...project} />)}
    </div>
  </section>
</Layout>
