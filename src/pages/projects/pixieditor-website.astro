---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";

const seo = {
  title: "PixiEditor 2.0 Website | Anna Kocaj",
  description:
    "Redesigning pixieditor.net for the 2.0 launch to prove the editor's breadth and fund the project through the Founder's Pack.",
  image: "/pixieditor-website-hero.png",
};
---

<Layout seo={seo}>
  <!-- HERO -->
  <section class="mt-10 max-w-2xl mx-auto px-6">
    <a
      href="/projects"
      class="inline-flex items-center gap-1 opacity-50 hover:opacity-100 transition-opacity text-sm mb-8"
    >
      ← Back to projects
    </a>

    <p class="text-sm opacity-50 uppercase tracking-widest mb-3 font-medium">
      Case Study · 2025
    </p>
    <h1 class="font-bold text-3xl mb-4 leading-snug">
      Redesigning pixieditor.net
    </h1>
    <a
      href="https://www.figma.com/design/1CyOD1iZ3xpeqR0Yjyyy6W/PixiEditor-2.0-Website?node-id=0-1&t=d6B2oAJvmSdYFzns-1"
      target="_blank"
      rel="noopener noreferrer"
      class="group/link inline-flex items-center gap-2 rounded-full border border-white/10 px-5 py-2.5 text-sm font-medium opacity-70 hover:opacity-100 hover:border-accent transition-all duration-300 mb-4 w-fit"
    >
      View in Figma
      <span
        aria-hidden="true"
        class="transition-transform duration-300 group-hover/link:translate-x-0.5"
        >→</span
      >
    </a>
    <p class="text-lg opacity-70 mb-8 max-w-xl leading-relaxed">
      A website built to prove PixiEditor could replace your design toolkit.
    </p>

    <!-- Overview grid -->
    <div
      class="grid grid-cols-2 sm:grid-cols-4 gap-4 py-6 border-t border-b border-white/10 mb-10"
    >
      <div>
        <p class="text-xs uppercase tracking-widest opacity-40 mb-1">My Role</p>
        <p class="text-sm font-medium">Product Designer</p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-widest opacity-40 mb-1">Tools</p>
        <p class="text-sm font-medium">Figma</p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-widest opacity-40 mb-1">
          Live site
        </p>
        <p class="text-sm font-medium">
          <a
            href="https://pixieditor.net"
            class="underline"
            target="_blank"
            rel="noopener">pixieditor.net</a
          >
        </p>
      </div>
    </div>

    <!-- Hero image -->
    <div class="rounded-xl overflow-hidden m-6 bg-gray-800">
      <Image
        src="/pixi_thumbnail.png"
        alt="PixiEditor thumbnail"
        width={1200}
        height={675}
        class="w-full object-cover"
      />
    </div>
  </section>

  <!-- CHALLENGE -->
  <section class="max-w-2xl mx-auto px-6 mb-16">
    <h2 class="font-semibold text-xl mb-4">The Challenge</h2>
    <p class="opacity-70 leading-relaxed mb-4">
      PixiEditor had grown from a pixel art tool into a universal 2D graphics
      editor with procedural art, vector design, image editing, drawing, and
      animation, alongside its pixel art roots.
    </p>
    <p class="opacity-70 leading-relaxed">
      As an open-source project, the Founder's Bundle, sold directly through
      this site, was our
      <strong>main source of funding</strong>. It had to earn enough trust from
      visitors of a free, community-driven project to convince them to actually
      pay for it.
    </p>
  </section>

  <!-- PROCESS -->
  <section class="max-w-2xl mx-auto px-6 mb-16">
    <h2 class="font-semibold text-xl mb-8">Process</h2>

    <div class="space-y-12">
      <!-- Step 1 -->
      <div>
        <p
          class="text-xs uppercase tracking-widest opacity-40 mb-2 font-medium"
        >
          01 — Define
        </p>
        <h3 class="font-medium text-base mb-3">All in one</h3>
        <p class="opacity-70 leading-relaxed text-sm">
          The old site led with pixel art and buried everything else,
          undermining the "universal editor" positioning we needed for 2.0. At
          the same time, asking a visitor to pay for free, open-source software
          is a harder sell than a typical SaaS checkout. We needed to build real
          credibility before ever mentioning the Founder's Bundle.
        </p>
      </div>

      <!-- Step 2 -->
      <div>
        <p
          class="text-xs uppercase tracking-widest opacity-40 mb-2 font-medium"
        >
          02 — Concept
        </p>
        <h3 class="font-medium text-base mb-3">Finding the right structure</h3>
        <p class="opacity-70 leading-relaxed text-sm mb-4">
          I opened the new homepage with a tagline "Universal 2D Graphics
          Editor, one to rule them all" followed by a scannable breakdown of
          PixiEditor's six core capabilities: Procedural Art, Pixel Art, Image
          Editing, Drawing, Vector Art, and Animations. A visitor who came in
          thinking "pixel art tool" could see within seconds everything else it
          actually did.
        </p>
        <!-- TODO: replace with a screenshot of the six-category breakdown section -->
        <div class="rounded-xl overflow-hidden m-6 bg-gray-800">
          <Image
            src="/pixi_hero.png"
            alt="PixiEditor website six-category feature breakdown"
            width={1200}
            height={675}
            class="w-full object-cover"
          />
        </div>
      </div>

      <!-- Step 3 -->
      <div>
        <p
          class="text-xs uppercase tracking-widest opacity-40 mb-2 font-medium"
        >
          03 — Design & Ship
        </p>
        <h3 class="font-medium text-base mb-3">
          Designing, filming, and shipping
        </h3>
        <p class="opacity-70 leading-relaxed text-sm">
          I designed the full site in Figma, produced the launch videos and
          written content, and worked directly with our developers during
          implementation to make sure the final build matched the design intent.
        </p>
        <!-- TODO: replace with a screenshot of the trust/social proof section -->
        <div class="rounded-xl overflow-hidden m-6 bg-gray-800">
          <Image
            src="/pixi_reviews.png"
            alt="PixiEditor website trust and social proof section"
            width={1200}
            height={675}
            class="w-full object-cover"
          />
        </div>
      </div>
    </div>

    <!-- OUTCOMES -->
    <section class="max-w-2xl mx-auto px-6 mb-16">
      <h2 class="font-semibold text-xl mb-6">Outcomes</h2>
      <div class="grid grid-cols-1 sm:grid-cols-1 gap-4 mb-4">
        <div class="p-6 rounded-xl border border-white/10 bg-white/5">
          <p class="text-4xl font-bold mb-1">500+ sales</p>
          <p class="text-sm opacity-60">of Founder's Bundle in one year.</p>
        </div>
      </div>
    </section>
  </section>

  <!-- NAVIGATION -->
  <section
    class="max-w-2xl mx-auto px-6 mb-16 flex justify-center items-center border-t border-white/10 pt-8"
  >
    <a
      href="/projects"
      class="opacity-50 hover:opacity-100 transition-opacity text-sm"
    >
      ← All projects
    </a>
  </section>
</Layout>

<style>
  strong {
    color: white;
    font-weight: 600;
  }
  em {
    color: inherit;
  }
</style>
